{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Polaris",
  "version": "0.2.10",
  "identifier": "com.polaris.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "北极星 · Polaris",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gh-proxy.com/https://github.com/wuli2025/gaokaozhiyuan/releases/latest/download/latest.json",
        "https://github.com/wuli2025/gaokaozhiyuan/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyOTE3RUQ2RTExMEE1QTgKUldTb3BSRGgxbjZSRWtmTDBvUVlDR1hSTkIzY0k4TGRKbTJxOWtmRUpDMUYyL01LYnViWTVVNy8K",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/seed-kb/**/*"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "本地优先 AI 工作台",
    "longDescription": "Polaris 是一个本地优先的 AI 工作台,集成 Claude Code 对话、维基知识库和 Docker 安全沙箱。",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "compression": "lzma",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
