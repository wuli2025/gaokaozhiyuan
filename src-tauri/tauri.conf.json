{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "高智愿",
  "version": "0.2.12",
  "identifier": "com.gaokaozhiyuan.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "高智愿",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gh-proxy.com/https://github.com/wuli2025/gaokaozhiyuan/releases/latest/download/latest.json",
        "https://github.com/wuli2025/gaokaozhiyuan/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyOTE3RUQ2RTExMEE1QTgKUldTb3BSRGgxbjZSRWtmTDBvUVlDR1hSTkIzY0k4TGRKbTJxOWtmRUpDMUYyL01LYnViWTVVNy8K",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/seed-kb/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "高智愿 · 高考志愿智能冲稳保",
    "longDescription": "高智愿——高考志愿填报助手，集成位次法匹配、Wiki 知识库、升学路径规划，为学生和家庭提供数据驱动的志愿填报决策支持。",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "compression": "lzma",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
